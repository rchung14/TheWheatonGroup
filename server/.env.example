# Copy to .env (gitignored) and fill in real values. Never commit .env.

# Resend — transactional email
RESEND_API_KEY=
EMAIL_USER=

# Where contact-form and job-application emails are delivered
CONTACT_EMAIL=will@wheaton-group.com

# Firebase Admin (Render sets FIREBASE_SERVICE_ACCOUNT as the full JSON;
# local dev falls back to database/serviceAccountKey.json, also gitignored)
FIREBASE_SERVICE_ACCOUNT=
FIREBASE_DATABASE_URL=

# Comma-separated list of browser origins allowed to call this API
ALLOWED_ORIGINS=https://www.wheaton-group.com,https://wheaton-group.com,http://localhost:3000

PORT=5000
